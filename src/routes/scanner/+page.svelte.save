<script lang="ts">
/**
 * Scanner engine strategy:
 *
 * 1. BarcodeDetector (native) — Chrome/Edge/Android WebView
 *    - Stream via getUserMedia → <video>
 *    - Detect via requestAnimationFrame loop → ~60fps, zero extra library cost
 *
 * 2. Html5Qrcode (fallback) — Firefox / Safari / older browser
 *    - Manages its own stream inside a hidden div (#h5q-container)
 *    - fps: 15, useBarCodeDetectorIfSupported: false (already checked above)
 *
 * Camera list: Html5Qrcode.getCameras() (works on both paths)
 */

import { onDestroy, onMount } from "svelte";
import { Html5Qrcode, Html5QrcodeSupportedFormats } from "html5-qrcode";
import type { PageProps } from "./$types";
import Fuse from "fuse.js";
import { TicketCheck, TicketMinus, ChevronDown, FlipHorizontal2, Cctv } from "lucide-svelte";
import { toast } from "svelte-sonner";
import { isWithin3Months } from "$lib/helper/within3Month";
import { toTitleCase } from "$lib/helper/titleCase";
import type { LogMeta } from "$lib/types/log";
import { browser } from "$app/environment";

const { data }: PageProps = $props();

// ─── Types ───────────────────────────────────────────────────────────────────
type CheckedEntry = {
  status: "terpakai" | "invalid" | "dalam-3-bulan" | "valid";
  checked: boolean;
  id: string;
};
type Log = {
  id: number; jobId: string; status: string; source: string;
  createdAt: Date; level: "info" | "warn" | "error"; meta?: LogMeta;
};
type CameraDevice = { id: string; label: string };

// ─── Declare BarcodeDetector (not in TS lib yet) ─────────────────────────────
declare class BarcodeDetector {
  static getSupportedFormats(): Promise<string[]>;
  constructor(opts?: { formats?: string[] });
  detect(source: HTMLVideoElement | HTMLCanvasElement | ImageBitmap): Promise<{ rawValue: string; format: string }[]>;
}

// ─── State ───────────────────────────────────────────────────────────────────
let scanning      = $state(false);
let scannerReady  = $state(false);
let engineUsed    = $state<"native" | "h5q" | null>(null);

let result        = $state<typeof data.recipients | null>(null);
let search        = $state("");

// Native path
let videoEl       = $state<HTMLVideoElement | null>(null);
let stream        = $state<MediaStream | null>(null);
let rafId         = $state<number>(0);
let detector      = $state<BarcodeDetector | null>(null);

// h5q fallback path
let h5q           = $state<Html5Qrcode | null>(null);

let ticketBtnHover = $state<{ [k: number]: boolean }>({});
let lastText       = $state<string | null>(null);
let lastAt         = $state<number>(0);

let checkedData   = $state<Map<string, CheckedEntry>>(new Map());
let logs          = $state<Log[]>([]);
let openGroups    = $state<Set<string>>(new Set());

let deviceId      = $state<string | null>(null);
let devices       = $state<CameraDevice[]>([]);
let showCamPicker = $state(false);

const COOLDOWN     = 800;
const SAME_COOLDOWN = 3000;
const H5Q_FORMATS  = [
  Html5QrcodeSupportedFormats.QR_CODE,
  Html5QrcodeSupportedFormats.CODE_128,
  Html5QrcodeSupportedFormats.CODE_39,
  Html5QrcodeSupportedFormats.EAN_13,
  Html5QrcodeSupportedFormats.EAN_8,
  Html5QrcodeSupportedFormats.DATA_MATRIX,
];

// ─── Server data sync ─────────────────────────────────────────────────────────
$effect(() => {
  const updates = new Map<string, CheckedEntry>();
  for (const r of data.recipients) {
    if (checkedData.has(r.id)) continue;
    const c = r.coupon;
    if (!c) continue;
    const h = c.history.length > 0
      ? c.history.reduce((a, b) => new Date(b.createdAt) > new Date(a.createdAt) ? b : a)
      : null;
    if (!h) continue;
    const isUsed   = h.status === "USED";
    const isRecent = isWithin3Months(h.createdAt);
    if (isUsed && !isRecent) continue;
    updates.set(r.id, {
      id: r.id, checked: isUsed && isRecent,
      status: isUsed && isRecent ? "dalam-3-bulan" : "valid",
    });
  }
  if (updates.size > 0) checkedData = new Map([...checkedData, ...updates]);
});

// ─── Log groups ──────────────────────────────────────────────────────────────
const logGroups = $derived.by(() => {
  const g = new Map<string, Log[]>();
  for (const l of logs) {
    const k = l.meta?.recipientId ?? "unknown";
    const e = g.get(k);
    if (e) e.push(l); else g.set(k, [l]);
  }
  return g;
});

// ─── Fuse search ─────────────────────────────────────────────────────────────
const fuseData = new Fuse(data.recipients, {
  keys: ["name", "address", "coupon.code"], threshold: 0.4,
});
let debounceTimer: ReturnType<typeof setTimeout>;

function runSearch(v: string) {
  result = v ? fuseData.search(v).map((d) => d.item) : null;
}
function handleInput(v: string) {
  search = v;
  clearTimeout(debounceTimer);
  debounceTimer = setTimeout(() => runSearch(v), 200);
}

// ─── Scan result handler ─────────────────────────────────────────────────────
function onScanResult(raw: string) {
  const now = Date.now();
  if (raw === lastText && now - lastAt < SAME_COOLDOWN) return;
  if (now - lastAt < COOLDOWN && raw !== lastText) return;
  lastText = raw;
  lastAt   = now;
  const clean = parseInt(raw.replace(/#/g, "").trim()).toString();
  search = clean;
  runSearch(clean);
}

// ─── Check (ceklis) ──────────────────────────────────────────────────────────
function checkData(payload: { id: string; code: number }) {
  const tid = toast.loading("Menceklis kupon...");
  const m = new Map(checkedData);
  m.set(payload.id, { id: payload.id, checked: true, status: "terpakai" });
  checkedData = m;
  fetch("/api/check", { method: "POST", body: JSON.stringify(payload) });
  toast.success("Kupon diceklis", { id: tid });
}

// ─── Camera list ─────────────────────────────────────────────────────────────
async function loadDevices() {
  if (!browser) return;
  try {
    // trigger permission prompt
    const tmp = await navigator.mediaDevices.getUserMedia({ video: true });
    tmp.getTracks().forEach((t) => t.stop());

    const list = await Html5Qrcode.getCameras();
    devices = list;
    const back = list.find((d) => /back|belakang|environment/i.test(d.label));
    if (!deviceId) deviceId = back?.id ?? list[0]?.id ?? null;
  } catch (e: any) {
    toast.error("Gagal mendapat kamera: " + (e.message ?? String(e)));
  }
}

// ─── Native BarcodeDetector path ────────────────────────────────────────────
function rafLoop() {
  if (!detector || !videoEl || videoEl.readyState < 2) {
    rafId = requestAnimationFrame(rafLoop);
    return;
  }
  detector.detect(videoEl).then((barcodes) => {
    if (barcodes.length > 0) onScanResult(barcodes[0].rawValue);
  }).catch(() => {/* frame decode error, skip */});
  rafId = requestAnimationFrame(rafLoop);
}

async function startNative(camId: string) {
  // Detect what formats the native API supports, pick intersection
  let formats: string[];
  try {
    const supported = await BarcodeDetector.getSupportedFormats();
    const want = ["qr_code", "code_128", "code_39", "ean_13", "ean_8", "data_matrix"];
    formats = want.filter((f) => supported.includes(f));
    if (formats.length === 0) formats = supported; // fallback: all
  } catch {
    formats = ["qr_code", "code_128", "ean_13"];
  }

  detector = new BarcodeDetector({ formats });

  stream = await navigator.mediaDevices.getUserMedia({
    video: {
      deviceId: { exact: camId },
      width: { ideal: 1280 },
      height: { ideal: 720 },
      frameRate: { ideal: 30 },
    },
    audio: false,
  });

  if (!videoEl) throw new Error("videoEl not mounted");
  videoEl.srcObject = stream;
  await videoEl.play();

  scannerReady = true;
  engineUsed   = "native";
  rafId        = requestAnimationFrame(rafLoop);
}

function stopNative() {
  cancelAnimationFrame(rafId);
  stream?.getTracks().forEach((t) => t.stop());
  stream  = null;
  detector = null;
  if (videoEl) { videoEl.srcObject = null; }
}

// ─── Html5Qrcode fallback path ───────────────────────────────────────────────
async function startH5Q(camId: string) {
  // Html5Qrcode needs a real DOM div with an id
  const el = document.getElementById("h5q-container");
  if (!el) throw new Error("h5q-container not found");

  h5q = new Html5Qrcode("h5q-container", {
    formatsToSupport: H5Q_FORMATS,
    verbose: false,
  });

  await h5q.start(
    { deviceId: { exact: camId } },
    {
      fps: 15,
      // qrbox: tidak set → full frame scanning (lebih cepat detect dari jarak jauh)
      aspectRatio: 16 / 9,
      useBarCodeDetectorIfSupported: false, // sudah dicek tidak ada
    },
    (text) => onScanResult(text),
    (_err) => { /* frame error, ignore */ },
  );

  scannerReady = true;
  engineUsed   = "h5q";
}

async function stopH5Q() {
  if (h5q) {
    try { await h5q.stop(); } catch { /* already stopped */ }
    h5q.clear();
    h5q = null;
  }
}

// ─── Start / Stop / Switch ───────────────────────────────────────────────────
async function startScan() {
  if (!deviceId) return;
  result = null; scannerReady = false; lastText = null;

  const hasNative = browser && "BarcodeDetector" in globalThis;

  try {
    scanning = true;
    if (hasNative) {
      await startNative(deviceId);
    } else {
      await startH5Q(deviceId);
    }
  } catch (e: any) {
    scanning     = false;
    scannerReady = false;
    engineUsed   = null;
    toast.error("Gagal kamera: " + (e.message ?? String(e)));
  }
}

async function stopScan() {
  if (engineUsed === "native") stopNative();
  else if (engineUsed === "h5q") await stopH5Q();
  scanning     = false;
  scannerReady = false;
  engineUsed   = null;
  lastText     = null;
}

async function switchCamera(id: string) {
  const was = scanning;
  if (was) await stopScan();
  deviceId      = id;
  showCamPicker = false;
  if (was) {
    await new Promise((r) => setTimeout(r, 250));
    await startScan();
  }
}

// ─── Log toggle ───────────────────────────────────────────────────────────────
function toggleGroup(id: string) {
  const s = new Set(openGroups);
  if (s.has(id)) s.delete(id); else s.add(id);
  openGroups = s;
}

// ─── Helpers ─────────────────────────────────────────────────────────────────
function camLabel(d: CameraDevice, i: number) {
  if (!d.label) return `Kamera ${i + 1}`;
  return d.label.length > 32 ? d.label.slice(0, 30) + "…" : d.label;
}

// ─── Lifecycle ───────────────────────────────────────────────────────────────
onMount(async () => {
  await loadDevices();
  const es = new EventSource("/api/logs");
  es.onmessage = (e) => { const l = JSON.parse(e.data); logs = [l, ...logs]; };
  return () => es.close();
});

onDestroy(async () => {
  await stopScan();
  clearTimeout(debounceTimer);
});
</script>

<div class="min-h-screen bg-neutral-950 text-neutral-200 font-sans text-sm">

  <!-- App bar -->
  <header class="sticky top-0 z-20 flex items-center gap-3 h-14 px-4
    bg-neutral-900 border-b border-neutral-800">
    <Cctv size={18} class="text-teal-400" />
    <span class="font-semibold text-neutral-100 tracking-tight">Scan Kurban</span>
    {#if engineUsed}
      <span class="ml-auto text-[10px] font-mono px-2 py-0.5 rounded
        {engineUsed === 'native' ? 'bg-teal-500/10 text-teal-400' : 'bg-amber-500/10 text-amber-400'}">
        {engineUsed === 'native' ? 'BarcodeDetector' : 'Html5Qrcode'}
      </span>
    {/if}
  </header>

  <div class="max-w-md mx-auto px-4 py-4 flex flex-col gap-3">

    <!-- ── Camera card ──────────────────────────────────────────────────── -->
    <div class="rounded-xl bg-neutral-900 border border-neutral-800 overflow-hidden">

      <!-- Viewfinder (native path) -->
      <div class="relative aspect-video bg-black flex items-center justify-center
        {engineUsed === 'h5q' ? 'hidden' : ''}">

        {#if !scanning}
          <div class="flex flex-col items-center gap-2 text-neutral-600">
            <svg class="w-10 h-10" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="4" y="4" width="14" height="14" rx="2"/>
              <rect x="30" y="4" width="14" height="14" rx="2"/>
              <rect x="4" y="30" width="14" height="14" rx="2"/>
              <rect x="7" y="7" width="8" height="8" rx="1" fill="currentColor" stroke="none" opacity=".4"/>
              <rect x="33" y="7" width="8" height="8" rx="1" fill="currentColor" stroke="none" opacity=".4"/>
              <rect x="7" y="33" width="8" height="8" rx="1" fill="currentColor" stroke="none" opacity=".4"/>
              <path d="M30 30h4v4h-4zM38 30h4v4h-4zM30 38h4v4h-4zM38 38h4v4h-4z"
                fill="currentColor" stroke="none" opacity=".4"/>
            </svg>
            <p class="text-xs">Kamera tidak aktif</p>
          </div>
        {/if}

        <!-- svelte-ignore a11y_media_has_caption -->
        <video bind:this={videoEl}
          class="absolute inset-0 w-full h-full object-cover"
          autoplay playsinline muted></video>

        {#if scanning && engineUsed === 'native'}
          <div class="absolute inset-0 bg-black/25 pointer-events-none"></div>
          <!-- Finder corners -->
          <div class="absolute w-44 h-16 pointer-events-none">
            <span class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-teal-400 rounded-tl"></span>
            <span class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-teal-400 rounded-tr"></span>
            <span class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-teal-400 rounded-bl"></span>
            <span class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-teal-400 rounded-br"></span>
            <div class="laser absolute left-1 right-1 h-px
              bg-gradient-to-r from-transparent via-teal-400 to-transparent"></div>
          </div>
          <!-- Status chip -->
          <div class="absolute top-2 left-2 flex items-center gap-1.5
            bg-black/60 rounded-full px-2.5 py-1 text-[10px]
            {scannerReady ? 'text-emerald-400' : 'text-neutral-500'}">
            <span class="w-1.5 h-1.5 rounded-full bg-current
              {scannerReady ? 'animate-pulse' : ''}"></span>
            {scannerReady ? "Aktif" : "Memulai…"}
          </div>
          {#if lastText}
            <div class="absolute top-2 right-2 bg-black/60 rounded-full
              px-2.5 py-1 text-[10px] text-teal-300 font-mono max-w-[45%] truncate">
              ✓ {lastText}
            </div>
          {/if}
          <!-- Switch cam -->
          {#if devices.length > 1}
            <button onclick={() => (showCamPicker = !showCamPicker)}
              class="absolute bottom-2 right-2 w-8 h-8 flex items-center justify-center
                rounded-full bg-black/60 border border-neutral-700
                text-neutral-300 hover:text-white transition-colors">
              <FlipHorizontal2 size={15} />
            </button>
          {/if}
        {/if}
      </div>

      <!--
        Html5Qrcode fallback container.
        Html5Qrcode renders its own <video> inside here.
        We let it show naturally when engineUsed === 'h5q'.
        The library injects its own UI; we hide non-video children via CSS.
      -->
      <div id="h5q-container"
        class="w-full {engineUsed === 'h5q' ? 'block' : 'hidden'}"
        style="aspect-ratio: 16/9; overflow: hidden;">
      </div>

      <!-- Camera picker dropdown (saat scanning) -->
      {#if showCamPicker && scanning && devices.length > 1}
        <div class="border-t border-neutral-800 bg-neutral-950">
          <p class="px-4 pt-2.5 pb-1 text-[10px] font-semibold uppercase tracking-widest text-neutral-600">
            Pilih Kamera
          </p>
          {#each devices as d, i}
            <button onclick={() => switchCamera(d.id)}
              class="w-full flex items-center gap-2 px-4 py-2.5 text-sm text-left transition-colors
                {d.id === deviceId
                  ? 'text-teal-400 bg-teal-400/5'
                  : 'text-neutral-300 hover:bg-neutral-800'}">
              <span class="flex-1 truncate">{camLabel(d, i)}</span>
              {#if d.id === deviceId}
                <span class="text-[10px] font-semibold uppercase tracking-wide
                  text-teal-500 bg-teal-500/10 px-2 py-0.5 rounded">aktif</span>
              {/if}
            </button>
          {/each}
        </div>
      {/if}

      <!-- Camera chips (saat idle) -->
      {#if !scanning && devices.length > 1}
        <div class="border-t border-neutral-800 px-4 py-3">
          <p class="text-[10px] font-semibold uppercase tracking-widest text-neutral-600 mb-2">Kamera</p>
          <div class="flex flex-wrap gap-1.5">
            {#each devices as d, i}
              <button onclick={() => (deviceId = d.id)}
                class="text-xs px-3 py-1 rounded-full border transition-colors truncate max-w-[180px]
                  {d.id === deviceId
                    ? 'border-teal-500 bg-teal-500/10 text-teal-400'
                    : 'border-neutral-700 text-neutral-400 hover:border-neutral-500'}"
                title={d.label}>
                {camLabel(d, i)}
              </button>
            {/each}
          </div>
        </div>
      {/if}

      <!-- Action button -->
      <div class="px-4 py-3">
        {#if !scanning}
          <button onclick={startScan} disabled={!deviceId}
            class="w-full h-10 rounded-lg bg-teal-500 text-neutral-950 font-semibold
              hover:bg-teal-400 active:scale-[.98]
              disabled:opacity-30 disabled:cursor-not-allowed transition-all">
            Mulai Scan
          </button>
        {:else}
          <button onclick={stopScan}
            class="w-full h-10 rounded-lg bg-neutral-800 border border-neutral-700
              text-neutral-300 font-medium hover:bg-neutral-700
              active:scale-[.98] transition-all">
            Berhenti
          </button>
        {/if}
      </div>
    </div>

    <!-- ── Manual search ────────────────────────────────────────────────── -->
    <div class="rounded-xl bg-neutral-900 border border-neutral-800 p-4 flex flex-col gap-2">
      <p class="text-[10px] font-semibold uppercase tracking-widest text-neutral-600">Input Manual</p>
      <input type="search"
        placeholder="Nama atau kode kupon…"
        class="w-full h-10 px-3 rounded-lg bg-neutral-800 border border-neutral-700
          text-neutral-100 placeholder:text-neutral-600
          focus:outline-none focus:border-teal-600 transition-colors"
        oninput={(e) => handleInput(e.currentTarget.value)} />
    </div>

    <!-- ── Results ──────────────────────────────────────────────────────── -->
    {#if result}
      <div class="rounded-xl bg-neutral-900 border border-neutral-800 overflow-hidden">
        <div class="px-4 py-3 border-b border-neutral-800 flex items-center gap-2">
          <p class="text-[10px] font-semibold uppercase tracking-widest text-neutral-600">Hasil</p>
          <span class="text-xs text-teal-400 font-mono">{search}</span>
          <span class="ml-auto text-xs text-neutral-600">{result.length} data</span>
        </div>
        <div class="divide-y divide-neutral-800">
          {#each result as item, index}
            {@const entry = checkedData.get(item.id)}
            <div class="flex items-center gap-3 px-4 py-3
              {entry?.status === 'dalam-3-bulan' ? 'bg-amber-500/5'
              : entry?.status === 'terpakai' ? 'bg-red-500/5' : ''}">
              <span class="font-mono text-xs text-teal-400 w-10 shrink-0">
                #{item.coupon.code.toString().padStart(4, "0")}
              </span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-neutral-100 truncate">
                  {toTitleCase(item.name)}
                  {#if entry}
                    <span class="ml-1 text-[10px] font-semibold uppercase px-1.5 py-0.5 rounded
                      {entry.status === 'dalam-3-bulan' ? 'bg-amber-500/15 text-amber-400'
                      : entry.status === 'terpakai' ? 'bg-red-500/15 text-red-400'
                      : 'bg-neutral-700 text-neutral-400'}">
                      {entry.status}
                    </span>
                  {/if}
                </p>
                <p class="text-xs text-neutral-500 truncate">{item.address}</p>
              </div>
              <button
                onclick={() => checkData({ id: item.id, code: item.coupon.code })}
                onpointerenter={() => (ticketBtnHover[index] = true)}
                onpointerleave={() => (ticketBtnHover[index] = false)}
                class="shrink-0 w-9 h-9 flex items-center justify-center rounded-lg
                  text-neutral-500 hover:text-teal-400 hover:bg-teal-400/10
                  active:scale-90 transition-all">
                {#if !ticketBtnHover[index] || entry?.checked}
                  <TicketMinus size={18} />
                {:else}
                  <TicketCheck size={18} />
                {/if}
              </button>
            </div>
          {/each}
        </div>
      </div>
    {/if}

    <!-- ── Activity log ─────────────────────────────────────────────────── -->
    {#if logs.length > 0}
      <div class="rounded-xl bg-neutral-900 border border-neutral-800 overflow-hidden">
        <div class="px-4 py-3 border-b border-neutral-800 flex items-center justify-between">
          <p class="text-[10px] font-semibold uppercase tracking-widest text-neutral-600">Activity Log</p>
          <span class="text-xs text-neutral-600">{logGroups.size} grup · {logs.length} entri</span>
        </div>
        <div class="divide-y divide-neutral-800">
          {#each logGroups as [recipientId, groupLogs]}
            {@const isOpen   = openGroups.has(recipientId)}
            {@const hasError = groupLogs.some((l) => l.level === "error")}
            {@const hasWarn  = groupLogs.some((l) => l.level === "warn")}
            {@const recip    = data.recipients.find((d) => d.id === recipientId)}
            <div>
              <button onclick={() => toggleGroup(recipientId)}
                class="w-full flex items-center gap-2.5 px-4 py-3 text-left
                  hover:bg-neutral-800 transition-colors">
                <span class="transition-transform duration-200 text-neutral-600
                  {isOpen ? 'rotate-180' : ''}">
                  <ChevronDown size={13} />
                </span>
                <span class="w-1.5 h-1.5 rounded-full shrink-0
                  {hasError ? 'bg-red-500' : hasWarn ? 'bg-amber-400' : 'bg-emerald-500'}"></span>
                <span class="flex-1 text-xs text-neutral-300 truncate">
                  {!recip ? "— no recipient —" : toTitleCase(recip.name)}
                  {recip ? `(${recip.address})` : ""}
                </span>
                <span class="text-[10px] font-mono text-neutral-600 bg-neutral-800 px-1.5 py-0.5 rounded shrink-0">
                  {groupLogs.length}
                </span>
              </button>
              {#if isOpen}
                <div class="px-4 pb-3 flex flex-col gap-1.5">
                  {#each groupLogs as log}
                    <div class="flex items-start gap-2 px-3 py-2 rounded-lg text-xs font-mono
                      {log.level === 'error' ? 'bg-red-500/8 text-red-400'
                      : log.level === 'warn'  ? 'bg-amber-500/8 text-amber-400'
                      : 'bg-neutral-800 text-neutral-400'}">
                      <span class="text-[9px] uppercase tracking-widest shrink-0 pt-px opacity-60">
                        {log.level}
                      </span>
                      <span class="flex-1 break-all leading-relaxed">{log.status}</span>
                      <span class="text-[9px] opacity-40 shrink-0 whitespace-nowrap">
                        {new Date(log.createdAt).toLocaleTimeString("id-ID", {
                          hour: "2-digit", minute: "2-digit", second: "2-digit",
                        })}
                      </span>
                    </div>
                  {/each}
                </div>
              {/if}
            </div>
          {/each}
        </div>
      </div>
    {/if}

    <!-- ── Logout ────────────────────────────────────────────────────────── -->
    <button onclick={async () => {
      if (confirm("Yakin untuk logout?")) {
        await fetch("/api/auth/logout"); location.reload();
      }
    }} class="self-center text-sm text-red-500 hover:text-red-400
      hover:bg-red-500/10 px-4 py-2 rounded-lg transition-colors">
      Logout
    </button>

  </div>
</div>

<style>
  /* Laser scanline animation — tidak bisa diekspresikan dengan Tailwind utility */
  .laser {
    top: 6px;
    animation: laser 1.8s ease-in-out infinite;
  }
  @keyframes laser {
    0%   { top: 6px; opacity: 1; }
    50%  { top: calc(100% - 6px); opacity: .5; }
    100% { top: 6px; opacity: 1; }
  }

  /*
    Paksa Html5Qrcode container mengisi parent tanpa overflow.
    Library inject inline style; kita override dengan !important di sini.
  */
  #h5q-container video {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }
  /* Sembunyikan UI bawaan Html5Qrcode (tombol, teks, dll) */
  #h5q-container > *:not(video) {
    display: none !important;
  }
</style>	
